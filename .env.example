# Nexus Agent — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.

# --- Runtime ---
PROJECT_NAME=Nexus Agent
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated browser origins for CORS (empty = disabled / same-origin only)
CORS_ORIGINS=
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,X-API-Key,X-Request-ID,Authorization
CORS_MAX_AGE=600  # preflight cache seconds
# Set to true to enable Prometheus /metrics endpoint (default: false)
EXPOSE_METRICS=false
# Per-provider deep health check timeout (GET /health/ready?deep=true)
# HEALTH_PROBE_TIMEOUT=5.0

# --- Dashboard ---
# Session signing key — REQUIRED in production (generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
SESSION_SECRET=
# Enable CSRF protection for dashboard POST forms
ENFORCE_DASHBOARD_CSRF=false

# --- Database ---
DATABASE_URL=sqlite:///./nexus.db
# Docker Compose SQLite: sqlite:////app/data/nexus.db (persisted under /app/data)
# DATABASE_URL=postgresql://user:pass@localhost:5432/nexus_db

# Connection pool (PostgreSQL only; SQLite ignores these)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800  # seconds; 0 = disabled
DB_POOL_PRE_PING=true
DB_POOL_TIMEOUT=30

# --- AI Provider Keys ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Local HF / Nexus Spin (model_id: local:repo/name or nexus-spin-v5.3) ---
LOCAL_HF_MODEL_ID=
LOCAL_HF_DEVICE=cpu
# Path to Doctrine Lab data/models/ for local-lora:<suffix> critic adapters
LOCAL_LORA_MODELS_ROOT=

# --- API Security ---
# Leave empty to disable auth (development mode)
NEXUS_API_KEY=              # Comma-separated for rotation: "new-key,old-key"
# Max requests per minute to expensive POST endpoints per IP (0 = unlimited)
RATE_LIMIT_RPM=30
# Max prompt characters accepted (0 = unlimited)
MAX_PROMPT_LENGTH=50000
MAX_REQUEST_BODY_BYTES=10485760  # 10 MB; 0 = disabled

# Legacy /api/ route deprecation — set an ISO date to add Sunset header
# API_LEGACY_SUNSET=2026-12-31
# Pipeline execution timeout (seconds; 0 = no timeout)
REQUEST_TIMEOUT_SECONDS=120
# Graceful shutdown drain deadline (seconds)
SHUTDOWN_DRAIN_SECONDS=30
# Streaming mode: buffered = zero-trust (tokens released only after checks pass);
# preview = opt-in early-token preview that may emit content before post-generation checks.
STREAM_ZERO_TRUST_MODE=buffered

# --- Governance ---
# Persistent EC private key PEM for capability-token signing (required in production).
# Generate: openssl ecparam -genkey -name prime256v1 -noout -out ecdsa.pem
# If unset, an ephemeral in-memory key is generated on each restart.
ECDSA_PRIVATE_KEY_PATH=
# Minimum approvers for K-of-N governance (default: 2)
APPROVAL_QUORUM=2
# Comma-separated reviewer IDs allowed to vote. Required in beta/production.
APPROVAL_REVIEWERS=

# --- A-S-FLC Decision Engine ---
ASFLC_UNCERTAINTY_DELTA=0.15
ASFLC_MAX_LOOPS=10
ASFLC_CONVERGENCE_THRESHOLD=0.01

# --- Multi-Model Compare ---
# Timeout for parallel LLM calls in /api/agent/compare (seconds)
COMPARE_TIMEOUT_SECONDS=30.0
# Maximum number of model_ids allowed per compare request
COMPARE_MAX_MODELS=5

# --- Critic Defaults ---
# Model used for LLM-backed critics (empty = use default provider)
CRITIC_MODEL=
CRITIC_CHUNK_SIZE=64
CRITIC_MAX_ROLLBACKS=3

# --- Data Retention (days; 0 = no automatic purge) ---
RETENTION_TRACE_DAYS=0
RETENTION_LABELING_DAYS=0
RETENTION_APPROVAL_DAYS=0
RETENTION_CALIBRATION_DAYS=0

# --- Multi-worker ---
# Set to "1" on secondary workers to prevent duplicate scheduler runs
# NEXUS_SKIP_SCHEDULER=0

# --- Agentic Loop (Phase 8) ---
# Max ReAct steps before the agent loop halts
AGENT_MAX_STEPS=25
# Working directory for agent file/shell tools (default: current directory)
AGENT_WORKSPACE=.
# Shell command timeout in seconds
AGENT_SHELL_TIMEOUT=30
# Max characters returned from tool output before truncation
AGENT_TOOL_OUTPUT_MAX_CHARS=20000
# Run reflection step even on success (default: true)
AGENT_REFLECT_ON_SUCCESS=true
# Run Arbiter critic evaluation every N agent steps (0 = only at end)
AGENT_CRITIC_EVERY_N_STEPS=0
# Use A-S-FLC decision analysis during agent planning
AGENT_USE_ASFLC=false
# Base URL for the Nexus API (used by CLI)
NEXUS_API_BASE_URL=http://localhost:9000

# --- Telegram Bot (Phase 8) ---
# Telegram bot token from @BotFather (leave empty to disable)
TELEGRAM_BOT_TOKEN=
# Long-poll timeout in seconds
TELEGRAM_POLL_TIMEOUT=30

# --- LOCAL_ONLY Mode (Phase 10) ---
# Set to true to block ALL outbound network calls (forces Ollama, disables web_fetch/search/doctrine)
LOCAL_ONLY=false

# --- Ollama (Phase 10) ---
# Base URL for local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434
# API key for Ollama (usually not needed)
OLLAMA_API_KEY=
# Default model to use when LOCAL_ONLY=true remaps a cloud model
OLLAMA_DEFAULT_MODEL=llama3
# List Ollama models alongside cloud providers
OLLAMA_LIST_IN_PROVIDERS=false

# --- Search API Keys (for agent web search tool) ---
# Tavily search API key
TAVILY_API_KEY=
# SerpAPI key (fallback)
SERPAPI_API_KEY=

# --- Doctrine Lab Integration ---
# URL of your Doctrine Lab instance for dataset import
DOCTRINE_LAB_URL=http://localhost:8000
DOCTRINE_LAB_API_KEY=

# --- Webhooks ---
# Enable webhook notifications for pipeline events
WEBHOOKS_ENABLED=false
# Number of async webhook delivery workers
WEBHOOK_WORKERS=2
# Retry: exponential backoff with full jitter
# WEBHOOK_MAX_RETRIES=3
# WEBHOOK_BACKOFF_BASE=1.0        # base delay in seconds
# WEBHOOK_BACKOFF_MAX=30.0        # cap delay in seconds
# WEBHOOK_REQUEST_TIMEOUT=10.0    # per-attempt HTTP timeout
# WEBHOOK_MAX_CONSECUTIVE_FAILURES=10  # auto-disable threshold

# --- Idempotency ---
# Prevent duplicate pipeline runs from retried requests
# Clients send Idempotency-Key header on POST /v1/agent/run, /v1/agent/compare
# IDEMPOTENCY_TTL=86400         # cached response lifetime in seconds (24h)
# IDEMPOTENCY_MAX_KEYS=10000    # max keys in in-process store

# --- Redis (multi-worker deployments) ---
# Set REDIS_URL for multi-worker rate limiting and idempotency (empty = in-process fallback)
REDIS_URL=
# Docker Compose prod: redis://redis:6379/0

# --- OpenTelemetry Distributed Tracing ---
# Enable OTel tracing (default: disabled, zero-cost no-op)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=nexus-agent
OTEL_EXPORTER_ENDPOINT=http://localhost:4318
OTEL_SAMPLE_RATE=1.0

# --- MCP Governance Proxy + Skill Import (Phase 11) ---
# Enable MCP Streamable HTTP mount at /mcp (requires MCP_ENABLED=true and LOCAL_ONLY=false)
MCP_ENABLED=false
# JSON file listing MCP backends (name, url, transport, enabled)
MCP_BACKENDS_FILE=mcp_backends.json
# Reserved for future use (policies live in DB)
MCP_DEFAULT_POLICY=deny
# Trace every MCP call; false = only denied/blocked/error paths
MCP_AUDIT_ALL=true

# --- Docker / Gunicorn ---
# Number of gunicorn worker processes (default: 2)
# GUNICORN_WORKERS=2
# Gunicorn worker timeout in seconds (should be >= REQUEST_TIMEOUT_SECONDS)
# GUNICORN_TIMEOUT=120
# Host port mapping (default: 9000)
# NEXUS_PORT=9000
# Postgres password (used by docker-compose prod profile)
# POSTGRES_PASSWORD=nexus
