# Nexus Agent — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.

# --- Database ---
DATABASE_URL=sqlite:///./nexus.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/nexus_db

# --- AI Provider Keys ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- API Security ---
# Leave empty to disable auth (development mode)
NEXUS_API_KEY=
# Max requests per minute to /api/agent/run per IP (0 = unlimited)
RATE_LIMIT_RPM=30

# --- Security ---
# ECDSA key pair is auto-generated on first run if not provided
ECDSA_PRIVATE_KEY_PATH=
# Minimum approvers for K-of-N governance (default: 2)
APPROVAL_QUORUM=2

# --- Doctrine Lab Integration ---
# URL of your Doctrine Lab instance for dataset import
DOCTRINE_LAB_URL=http://localhost:8000
DOCTRINE_LAB_API_KEY=
